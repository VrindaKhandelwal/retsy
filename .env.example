# ── Frontend (Next.js) ───────────────────────────────────────────────────
# Public URL of your Supabase Edge Functions, used by the browser.
# Local dev default shown; in production this looks like:
# https://<project-ref>.supabase.co/functions/v1
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=http://localhost:54321/functions/v1

# ── Supabase Edge Functions (set via `supabase secrets set` or the dashboard) ─
# Project URL and service role key (Project Settings > API). The service
# role key bypasses RLS — never expose it to the browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL, used to build links inside emails.
APP_URL=https://app.retsy.xyz

# OpenAI key used for extracting purchase details from forwarded emails.
OPENAI_API_KEY=

# Resend key used to send confirmation/reminder emails.
RESEND_API_KEY=

# Shared secret appended as ?secret=... to the Postmark inbound webhook URL,
# so only Postmark (who you configure with it) can post inbound emails.
POSTMARK_INBOUND_SECRET=

# Shared secret sent as the x-cron-secret header when triggering
# send-reminders on a schedule (see supabase/migrations/0002_schedule_reminders.sql).
CRON_SECRET=

# ── Gmail integration (V2) ────────────────────────────────────────────────
# OAuth client from the Google Cloud console (APIs & Services > Credentials).
# The consent screen must have the gmail.readonly scope and, while in
# Testing status, list each connecting Gmail address as a test user.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override the OAuth redirect URI for local dev
# (http://127.0.0.1:54321/functions/v1/gmail-oauth-callback). In production
# it's derived from SUPABASE_URL automatically.
# GOOGLE_REDIRECT_URI=
